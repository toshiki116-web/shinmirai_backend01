{
  "name": "sinmirai-ningensentakuki",
  "version": "0.0.1",
  "private": true,
  "description": "新・ミライ人間洗濯機 サーバーサイド",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcrypt"
    ]
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  }
}
