# =============================================================
# 環境変数テンプレート
# このファイルをコピーして .env を作成してください
#   cp .env.example .env
#
# 注意: 本物のAPIキー・シークレットをこのファイルに書かないこと
# すべてダミー値（DUMMY_*）で記載しています
# =============================================================

# データベース
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/sinmirai_db?schema=public"

# JWT認証
# 本番では必ず安全なランダム文字列に置き換えること（例: openssl rand -base64 32）
JWT_SECRET="DUMMY_JWT_SECRET_REPLACE_ME"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# AWS S3
AWS_REGION="ap-northeast-1"
AWS_S3_BUCKET="sinmirai-contents"
AWS_ACCESS_KEY_ID="DUMMY_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="DUMMY_SECRET_ACCESS_KEY"

# AWS CloudFront
AWS_CLOUDFRONT_DOMAIN="DUMMY_CLOUDFRONT_DOMAIN"
AWS_CLOUDFRONT_KEY_PAIR_ID="DUMMY_KEY_PAIR_ID"
AWS_CLOUDFRONT_PRIVATE_KEY="DUMMY_PRIVATE_KEY"

# サーバー設定
API_PORT=3000
NODE_ENV="development"

# 初期管理者
# 本番では必ず安全なパスワードに置き換えること
ADMIN_LOGIN_ID="admin"
ADMIN_INITIAL_EMAIL="kushida@artifice-inc.com"
ADMIN_PASSWORD="DUMMY_PASSWORD_REPLACE_ME"
